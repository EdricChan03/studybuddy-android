<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Login screen strings -->
    <eat-comment />

    <!-- Title for the login screen. -->
    <string name="title_activity_login">Sign in</string>

    <!-- Header title for the login authentication card. -->
    <string name="login_sign_in_header_text">Sign in to StudyBuddy</string>

    <!-- Header text for the sign-in providers section. -->
    <string name="sign_in_providers_header">Sign in with the below providers:</string>

    <string name="sign_in_providers_or">OR</string>

    <!-- The text of the sign in button in the login activity. -->
    <string name="login_sign_in_button_title">Login</string>

    <!-- The text of the forgot password button in the login activity. -->
    <string name="login_forgot_password_button_title">Forgot password</string>

    <!-- The text of the register button in the login activity's menu. -->
    <string name="login_register_button_title">Register for an account</string>

    <!-- Action text for the no internet connection snackbar. -->
    <string name="snackbar_internet_unavailable_action">Retry</string>
    <!-- Text for the no internet connection snackbar. -->
    <string name="login_internet_unavailable_snackbar_text">An internet connection is required to
        login.</string>
    <!-- Text for the logged-in snackbar. This string takes a single format argument,
    which should be the user's display name. -->
    <string name="login_success_snackbar_text">Signed in as %s</string>
    <!-- Text for the snack-bar that is shown when attempting to log-in results in an error. -->
    <string name="login_error_snackbar_text">An error occurred while logging in.
        Please try again later.</string>

</resources>
