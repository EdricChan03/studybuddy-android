<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Error text to be shown for required text fields. -->
    <string name="text_field_error_required">This field is required.</string>

    <!-- Helper text to be shown for text fields that have a limit. -->
    <string name="text_field_limit">Limit: %1$d / %2$d</string>
    <!-- Error semantics text to be used when the text field's max length has been exceeded. -->
    <string name="text_field_error_semantics_max_limit_exceeded">This field should not have more than %1$d
        characters, but %2$d characters were entered.
    </string>
    <!-- Error text to be used when the text field's max length has been exceeded. -->
    <string name="text_field_error_max_limit_exceeded">A maximum of %d characters can be entered.
    </string>

    <!-- Error semantics text to be used when the text field's min length has not been reached. -->
    <string name="text_field_error_semantics_min_limit_required">This field should not have less than %1$d
        characters, but %2$d characters were entered.
    </string>
    <!-- Error text to be used when the text field's min length has not been reached. -->
    <string name="text_field_error_min_limit_required">A minimum of %d characters is required.
    </string>
</resources>
